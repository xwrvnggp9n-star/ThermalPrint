# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# Built app bundle (regenerate with app/build_app.sh; the launcher bakes in an
# absolute path, so a built bundle isn't portable across machines anyway).
app/*.app/

# PyInstaller release output (regenerate with app/build_release.sh)
/dist/
/build/

# macOS
.DS_Store

# Logs
*.log

# Xcode / iOS
ios/build/
ios/DerivedData/
ios/**/xcuserdata/
ios/**/*.xcuserstate
ios/.build-screenshot-*.png
*.ipa

# OMC / Claude Code operational state
.claude/
